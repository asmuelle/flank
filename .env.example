# Names only — never commit values (see TOOLS.md / AGENTS.md).
# M1 runs entirely without any of these; they gate live integrations (M2+).

# Postgres + pgvector (docker-compose default: postgres://flank:flank@localhost:5432/flank)
DATABASE_URL=

# Raw HTML snapshot storage (S3-compatible)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# LLM (triage + synthesis). Absent => deterministic mock triage client is used.
ANTHROPIC_API_KEY=

# Crawl / unblock / discovery
FIRECRAWL_API_KEY=
ZYTE_API_KEY=
EXA_API_KEY=

# Scheduling / orchestration. inngest v4 defaults to cloud mode: the /api/inngest endpoint needs
# INNGEST_SIGNING_KEY in production, OR INNGEST_DEV=1 for local dev (or run `just inngest-dev`).
INNGEST_DEV=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Delivery — Slack uses a per-workspace incoming-webhook URL (stored per channel, no global token
# needed to send); email uses Resend. FLANK_ALERT_FROM is the verified Resend "from" address.
# Absent email creds => the delivery sweep records alerts as 'failed' rather than dialing out.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
RESEND_API_KEY=
FLANK_ALERT_FROM=

# Billing (M3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Web session signing — HMAC key for the signed session cookie. Must be >= 32 bytes; REQUIRED in
# production (the app refuses to start without it). AUTH_SESSION_SECRET wins; NEXTAUTH_SECRET is a
# fallback. Generate one with: openssl rand -base64 48
AUTH_SESSION_SECRET=
NEXTAUTH_SECRET=
