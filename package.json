{
  "name": "flank",
  "version": "0.1.0",
  "private": true,
  "description": "Living competitor radar for B2B SaaS — versioned cross-run diffing with span-pinned provenance.",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @flank/web dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "pnpm --filter @flank/web e2e",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm --filter @flank/web build",
    "migrate": "pnpm --filter @flank/db migrate",
    "seed": "tsx packages/db/scripts/seed.ts",
    "eval:triage": "tsx scripts/eval-triage.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@flank/core": "workspace:*",
    "@flank/pipeline": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "postcss": ">=8.5.10",
      "flatted": ">=3.4.2",
      "js-yaml": ">=4.2.0",
      "picomatch@4": ">=4.0.4",
      "minimatch@3": ">=3.1.3",
      "minimatch@9": ">=9.0.7"
    }
  }
}
